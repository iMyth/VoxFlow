# Vercel AI SDK Configuration
VITE_APP_AI_KEY=your-api-key-here

# API Endpoints
VITE_API_ENDPOINT=/api/chat/it-support
VITE_STT_ENDPOINT=/api/stt

# Backend API Base URL (for auth and other APIs)
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_BASE_URL=http://localhost:3000

# Keycloak Configuration
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=your-realm-name
VITE_KEYCLOAK_CLIENT_ID=your-client-id
VITE_KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# Sentry
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# GitLab Release
GITLAB_TOKEN=your-gitlab-token-here
GITLAB_PROJECT_ID=your-project-id

# Tauri Updater Signing Key
TAURI_SIGNING_PRIVATE_KEY=your-tauri-signing-private-key-here
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your-signing-password-here
